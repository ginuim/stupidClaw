{
  "name": "stupid-claw",
  "version": "0.1.6",
  "type": "module",
  "bin": {
    "stupid-claw": "./dist/index.js"
  },
  "files": [
    "dist",
    "public",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build:exe": "bun build ./src/index.ts --compile --outfile ./dist/stupidclaw"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "bun": "^1.3.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "dotenv": "^17.3.1",
    "picocolors": "^1.1.1",
    "ws": "^8.19.0"
  }
}
