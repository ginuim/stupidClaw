# --- 核心模型配置 ---
# 格式：provider:model_id
# 完整说明见 docs/models.md
#
# 内置云端 provider（设置 Key 后可直接使用）：
#   minimax        -> MINIMAX_API_KEY
#   minimax-cn     -> MINIMAX_CN_API_KEY(minimaxi.com)
#   openai         -> OPENAI_API_KEY
#   anthropic      -> ANTHROPIC_API_KEY
#   google         -> GEMINI_API_KEY
#   groq           -> GROQ_API_KEY
#   mistral        -> MISTRAL_API_KEY
#   xai            -> XAI_API_KEY
#   openrouter     -> OPENROUTER_API_KEY (可聚合 DeepSeek 等)
#   kimi-coding    -> KIMI_API_KEY
#   huggingface    -> HF_TOKEN
#
# 本地模型 (Ollama/LM Studio/vLLM)：先在 ~/.pi/agent/models.json 中注册，再在此填 provider:model_id
#
# 配置示例（创建 ~/.pi/agent/models.json）：
#   Ollama:   baseUrl: http://localhost:11434/v1,  models: [{ "id": "llama3.1:8b" }]
#   LM Studio: baseUrl: http://localhost:1234/v1,  models: [{ "id": "模型名" }]
#   vLLM:    baseUrl: http://localhost:8000/v1,   models: [{ "id": "模型名" }]
#   api: "openai-completions", apiKey: "ollama" (Ollama 可填任意值)
#
# 配置后在此处选择，例如：
#   STUPID_MODEL=ollama:llama3.1:8b
STUPID_MODEL=minimax-cn:MiniMax-M2.5

# --- 供应商密钥 (至少填一个) ---
# MINIMAX_API_KEY=
# MINIMAX_CN_API_KEY
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- 传输层配置 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# Webhook 配置 (仅当 TELEGRAM_MODE=webhook 时需要)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# --- IM 网页端配置 (StupidIM) ---
STUPID_IM_TOKEN=your_secret_token_here
# STUPID_IM_CHAT_ID= (可选，固定会话 ID)

# --- 调试 / 服务端口 ---
DEBUG_STUPIDCLAW=0
DEBUG_PROMPT=1
# Webhook 主服务端口；Polling 模式下 StupidIM 网页端也使用此端口
PORT=8080
