# --- 核心模型配置 ---
# 格式：provider:model_id
# 完整说明见 public/models.md 或 AGENTS.md
#
# 国内直连供应商（推荐国内用户）：
#   deepseek       -> DEEPSEEK_API_KEY         （deepseek-chat / deepseek-reasoner）
#   kimi           -> MOONSHOT_API_KEY          （moonshot-v1-128k / kimi-k2-0711-preview）
#   dashscope      -> DASHSCOPE_API_KEY         （qwen-max / qwen-plus / qwen-turbo）
#   bigmodel       -> ZHIPU_API_KEY             （glm-4 / glm-4-flash / glm-z1-flash）
#   minimax-cn     -> MINIMAX_CN_API_KEY        （MiniMax-M2.5）
#
# 海外供应商：
#   openai         -> OPENAI_API_KEY            （gpt-4o / o1-mini 等）
#   anthropic      -> ANTHROPIC_API_KEY         （claude-3-5-sonnet-20241022 等）
#   google         -> GEMINI_API_KEY            （gemini-2.0-flash 等）
#   groq           -> GROQ_API_KEY              （llama-3.3-70b-versatile，免费额度）
#   openrouter     -> OPENROUTER_API_KEY        （聚合平台，支持几乎所有模型）
#   xai            -> XAI_API_KEY               （grok-2-latest）
#
# 自定义兼容接口：
#   custom-openai     -> CUSTOM_OPENAI_API_KEY + CUSTOM_OPENAI_BASE_URL
#   custom-anthropic  -> CUSTOM_ANTHROPIC_API_KEY + CUSTOM_ANTHROPIC_BASE_URL
#
# 本地模型：
#   ollama     -> OLLAMA_BASE_URL（可选，默认 http://localhost:11434/v1）
#               示例：STUPID_MODEL=ollama:qwen2.5-coder:7b
#   其他本地服务（LM Studio/vLLM）-> 用 custom-openai，或在 ~/.pi/agent/models.json 中注册
#
STUPID_MODEL=deepseek:deepseek-chat

# --- 供应商密钥（至少填一个，与上方 STUPID_MODEL 对应）---
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
# MINIMAX_CN_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# CUSTOM_OPENAI_API_KEY=
# CUSTOM_OPENAI_BASE_URL=
# CUSTOM_ANTHROPIC_API_KEY=
# CUSTOM_ANTHROPIC_BASE_URL=

# --- Telegram 配置（不填则只能用 StupidIM 网页端）---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
# Webhook 配置（仅当 TELEGRAM_MODE=webhook 时需要）
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# --- StupidIM 网页端配置 ---
STUPID_IM_TOKEN=your_secret_token_here

# --- 调试 / 服务端口 ---
DEBUG_STUPIDCLAW=0
DEBUG_PROMPT=1
PORT=8080
